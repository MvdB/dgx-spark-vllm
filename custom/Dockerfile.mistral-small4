# Custom vLLM image for Mistral-Small-4 119B NVFP4 on DGX Spark (GB10, sm_120).
#
# Base: avarok/dgx-vllm-nvfp4-kernel:v23
#   Community image with sm_120-compatible NVFP4 GEMM kernels compiled in.
#   Required because vllm/vllm-openai:v0.17.1 lacks working FP4 GEMM for sm_120.
#
# Build:
#   docker build -t spark-mistral-small4:v1 -f custom/Dockerfile.mistral-small4 .
#
# Usage: vllm_spark.sh picks this image automatically via vllm_profile.conf.

FROM avarok/dgx-vllm-nvfp4-kernel:v23

RUN /opt/venv/bin/pip install --upgrade mistral_common
